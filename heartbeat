<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Particle Heart</title>

<style>
body{
    margin:0;
    overflow:hidden;
    background:#080b18;
}

canvas{
    display:block;
}
</style>
</head>
<body>

<canvas id="canvas"></canvas>

<script>
const canvas = document.getElementById("canvas");
const ctx = canvas.getContext("2d");

function resize(){
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
}
resize();
window.addEventListener("resize", resize);

const particles = [];
const TOTAL = 9000;

class Particle{
    constructor(){
        this.t = Math.random() * Math.PI * 2;
        this.offset = Math.random();
        this.size = Math.random() * 1.5 + 0.3;
    }

    draw(time){

        // nhịp tim mềm
        const beat =
            1 + Math.sin(time * 0.004) * 0.08;

        // công thức trái tim
        let x = 16 * Math.pow(Math.sin(this.t), 3);
        let y = -(
            13 * Math.cos(this.t)
            - 5 * Math.cos(2 * this.t)
            - 2 * Math.cos(3 * this.t)
            - Math.cos(4 * this.t)
        );

        // phân bố hạt tự nhiên như ảnh
        const spread = Math.random() * 12;

        const radius =
            0.75 + Math.random() * 0.35;

        x *= radius;
        y *= radius;

        const px =
            canvas.width/2 +
            x * 14 * beat +
            (Math.random()-0.5) * spread;

        const py =
            canvas.height/2 +
            y * 14 * beat +
            (Math.random()-0.5) * spread;

        // glow hồng
        const alpha =
            Math.random() * 0.7 + 0.3;

        ctx.beginPath();
        ctx.fillStyle =
            `rgba(255,120,170,${alpha})`;

        ctx.shadowBlur = 12;

        ctx.arc(
            px,
            py,
            this.size,
            0,
            Math.PI * 2
        );

        ctx.fill();
    }
}

for(let i=0;i<TOTAL;i++){
    particles.push(new Particle());
}

function animate(time){

    // blur frame để tạo hiệu ứng mềm như GIF
    ctx.fillStyle =
        "rgba(8,11,24,0.18)";
    ctx.fillRect(
        0,
        0,
        canvas.width,
        canvas.height
    );

    particles.forEach(p=>{
        p.draw(time);
    });

    requestAnimationFrame(animate);
}

animate();
</script>

</body>
</html>
